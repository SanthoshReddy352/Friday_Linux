    {"id": "strangler_fig_pattern", "label": "Strangler-fig migration pattern", "file_type": "rationale", "source_file": "docs/refactor_roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "FRIDAY 2.0 uses a strangler-fig migration pattern so the assistant remains fully functional at every phase boundary — no big-bang rewrite. The old CommandRouter is kept alive and load-bearing while each phase chips away at its responsibilities."},
    {"id": "langgraph_feature_flag", "label": "LangGraph optional execution engine feature flag", "file_type": "rationale", "source_file": "core/reasoning/graph_compiler.py", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "GraphCompiler uses a config flag routing.execution_engine to toggle between 'ordered' (OrderedToolExecutor fallback) and 'graph' (LangGraph StateGraph). If langgraph is not installed it silently falls back to the ordered executor — enabling optional dependency without breaking the system."},
    {"id": "three_tier_memory_pattern", "label": "Three-tier memory architecture (Episodic/Semantic/Procedural)", "file_type": "rationale", "source_file": "docs/refactor_roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Memory is split into Episodic (rolling 30-day turns), Semantic (key-value facts with confidence), and Procedural (bandit-style capability success rates) to match different lifecycle and access patterns."},
    {"id": "route_scorer_extraction_rationale", "label": "RouteScorer extraction from CommandRouter rationale", "file_type": "rationale", "source_file": "core/reasoning/route_scorer.py", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "RouteScorer was extracted from CommandRouter so CapabilityBroker can find the best route without importing the router at all, decoupling deterministic routing from the monolithic router class."}
